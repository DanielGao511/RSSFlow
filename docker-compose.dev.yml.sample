services:
  # 1. RSSHub (本地构建)
  rsshub:
    build: 
      context: ./rsshub
    ports:
      - "1200:1200"
    restart: always
    environment:
      NODE_ENV: dev
      CACHE_TYPE: redis
      REDIS_URL: "redis://redis:6379/"
      CACHE_EXPIRE: 120
    deploy:
      resources:
        limits:
          memory: 512M
    depends_on:
      - redis
 
  # 2. Bot (已集成 AI 总结)
  bot:
    build: 
      context: ./bot
    volumes:
      - ./bot_data:/app/config
    restart: always
    environment:
      # 使用测试 Token 进行开发调试
      TOKEN: ${TEST_TG_BOT_TOKEN}
      MANAGER: ${MANAGER}
      API_ID: ${API_ID}
      API_HASH: ${API_HASH}
      TELEGRAPH_TOKEN: ${TELEGRAPH_TOKEN}
      ALIYUN_API_KEY: ${ALIYUN_API_KEY}
      ALIYUN_BASE_URL: ${ALIYUN_BASE_URL}
      MODEL_NAME: ${MODEL_NAME}
      # HTTP_TIMEOUT: 300
      # T_PROXY: "socks5://x.x.x.x:xxxx"
    deploy:
      resources:
        limits:
          memory: 256M
    depends_on:
      - redis

  # 3. Redis (轻量级)
  redis:
    image: redis:alpine
    restart: always
    volumes:
      - ./redis_data:/data
    deploy:
      resources:
        limits:
          memory: 64M
